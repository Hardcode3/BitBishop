 # This is the configuration file template used to generate BitBishopConfig.cmake
 # during installation. It is used by consumers who do:
 #
 #     find_package(BitBishop REQUIRED)
 #
 # @PACKAGE_INIT@ sets up necessary variables and paths (like CMAKE_CURRENT_LIST_DIR).
 # We then include the BitBishopTargets.cmake file, which defines the library targets
 # so the consumer can link with BitBishop::BitBishopLib.
 #
 # This file is processed by configure_package_config_file() in CMakeLists.txt to produce
 # the final installed config file.

@PACKAGE_INIT@

include("${CMAKE_CURRENT_LIST_DIR}/BitBishopTargets.cmake")
